# ── 1. LLM Provider API Keys (set the one matching your provider) ──
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# ── 2. Model selection ───────────────────────────────────────────────────────
# Format: <provider>/<model>. Provider prefix drives which *_API_KEY is used.
# Defaults live in src/sim/config.py

# SIM_LLM_MODEL=openrouter/google/gemini-3.1-flash-lite-preview
# SIM_LLM_FALLBACK_MODEL=openrouter/google/gemini-3-flash-preview
